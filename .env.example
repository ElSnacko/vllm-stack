# ============================================================
# vLLM server configuration
# Copy to .env and customize:  cp .env.example .env
# ============================================================

# --- Model ---
# HuggingFace model ID (org/model-name)
# Must match a directory under llm_models/hf/
# Leave empty to get interactive model selection on first run
MODEL_NAME=

# --- Paths ---
# Host directory containing HuggingFace models
MODEL_DIR=./llm_models/hf
# HuggingFace cache (for tokenizer downloads at runtime)
HF_CACHE_DIR=~/.cache/huggingface

# --- Server ---
HOST_PORT=8080
PORT=8080
MAX_MODEL_LEN=8192
GPU_MEMORY_UTILIZATION=0.95
TENSOR_PARALLEL_SIZE=1
DTYPE=auto

# --- Performance ---
SHM_SIZE=4g
# Additional vLLM flags (e.g., "--enable-prefix-caching --enable-chunked-prefill")
EXTRA_ARGS=
