# GPU environment variables for vLLM container (NVIDIA CUDA)
# Uncomment/edit values to configure GPU settings.
#
# CUDA device selection (for multi-GPU setups):
# CUDA_VISIBLE_DEVICES=0

# vLLM v1 engine (default: enabled for better throughput)
# VLLM_USE_V1=1

# Worker multiproc method (spawn is safer, fork is faster)
# VLLM_WORKER_MULTIPROC_METHOD=spawn

# NCCL/分布式 settings (for tensor parallelism)
# NCCL_DEBUG=INFO
# NCCL_SOCKET_IFNAME=eth0

# vLLM logging
# VLLM_LOGGING_LEVEL=INFO
